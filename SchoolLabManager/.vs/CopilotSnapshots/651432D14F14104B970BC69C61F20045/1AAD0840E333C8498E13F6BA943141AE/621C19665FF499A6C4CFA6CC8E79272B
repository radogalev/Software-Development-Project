using SchoolLab.Core.Models;
using SchoolLab.Data.Context;
using SchoolLab.WinFormsUI.Dialogs;
using System;
using System.Drawing;
using System.Linq;
using System.Windows.Forms;

namespace SchoolLab.WinFormsUI.Controls
{
    public partial class UserItem : UserControl
    {
        public UserItem()
        {
            InitializeComponent();
        }

        public int UserId { get; private set; }

        public bool Selected
        {
            get { return this.BackColor == Color.DarkTurquoise; }
            set { this.BackColor = value ? Color.DarkTurquoise : Color.PaleTurquoise; }
        }

        public void Bind(User user)
        {
            if (user == null) return;
            UserId = user.Id;
            lblName.Text = user.Username ?? user.DisplayName ?? "User";
        }

        protected override void OnClick(EventArgs e)
        {
            base.OnClick(e);
        }

        protected override void OnDoubleClick(EventArgs e)
        {
            base.OnDoubleClick(e);

            try
            {
                using var context = new SchoolLabDbContext();
                var u = context.Users.FirstOrDefault(x => x.Id == UserId);

                if (u == null)
                {
                    MessageBox.Show(this, "User not found.", "Information", MessageBoxButtons.OK, MessageBoxIcon.Information);
                    return;
                }

                string message =
                    $"Username: {u.Username}\n" +
                    $"Full Name: {u.FullName}\n" +
                    $"Id: {u.Id}\n";

                using var dlg = new ShowInfoDialog(u.Username ?? "User", message);
                dlg.ShowDialog(this);
            }
            catch (Exception ex)
            {
                MessageBox.Show(this, "An error occurred while showing user details:\n" + ex.Message, "Error", MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
        }
    }
}
